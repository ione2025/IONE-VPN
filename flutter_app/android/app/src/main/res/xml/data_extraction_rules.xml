<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) data extraction rules.
  Excludes flutter_secure_storage from cloud backup AND device-to-device
  transfer. Without this exclusion, Android 12+ restores the encrypted
  SharedPreferences but not the Keystore keys, causing an immediate crash.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="FlutterSecureStorage"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="FlutterSecureStorage"/>
    </device-transfer>
</data-extraction-rules>
