# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ione_vpn

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_64_chars
JWT_REFRESH_EXPIRES_IN=30d

# ─── AmneziaWG (replaces vanilla WireGuard for DPI bypass) ──────────────────
# Run deploy/amneziawg_setup.sh on the server to generate these values.
AWG_INTERFACE=awg0
AWG_CONFIG_DIR=/etc/amnezia/amneziawg
AWG_SERVER_PUBLIC_KEY=<run: cat /etc/amnezia/amneziawg/publickey>
# Port 443/udp – disguised as QUIC/HTTPS; bypasses GFW and DPI firewalls.
AWG_SERVER_ENDPOINT=<your_droplet_ip>:443
AWG_SERVER_PRIVATE_KEY=<run: cat /etc/amnezia/amneziawg/privatekey>
AWG_SUBNET=10.9.9.0/24
AWG_DNS=1.1.1.1,8.8.8.8

# ── AmneziaWG obfuscation parameters ─────────────────────────────────────────
# MUST match [Interface] section of /etc/amnezia/amneziawg/awg0.conf exactly.
# All-zero = vanilla WireGuard speed with no DPI fingerprint (recommended).
# To unblock in actively-filtered networks: set AWG_S4=16, then AWG_JC=1.
AWG_JC=0
AWG_JMIN=0
AWG_JMAX=0
AWG_S1=0
AWG_S2=0
AWG_H1=1
AWG_H2=2
AWG_H3=3
AWG_H4=4

# Legacy WireGuard keys (kept for backward compat during migration)
WG_INTERFACE=awg0
WG_CONFIG_DIR=/etc/amnezia/amneziawg
WG_SERVER_PUBLIC_KEY=<same as AWG_SERVER_PUBLIC_KEY>
WG_SERVER_ENDPOINT=<same as AWG_SERVER_ENDPOINT>
WG_SERVER_PRIVATE_KEY=<same as AWG_SERVER_PRIVATE_KEY>
WG_SUBNET=10.9.9.0/24
WG_DNS=1.1.1.1,8.8.8.8

# ─── OpenVPN ─────────────────────────────────────────────────────────────────
OPENVPN_CONFIG_DIR=/etc/openvpn/server
OPENVPN_CA_CERT=/etc/openvpn/server/ca.crt

# ─── Server Info ─────────────────────────────────────────────────────────────
SERVER_REGION=Singapore
SERVER_COUNTRY=SG
SERVER_IP=<your_droplet_ip>

# ─── Stripe (Subscriptions) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_QUARTERLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@ionecenter.com
ADMIN_PASSWORD=change_this_strong_password

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Observability ───────────────────────────────────────────────────────────
# Set METRICS_TOKEN to enable the GET /metrics Prometheus endpoint.
# Leave blank to disable (endpoint returns 404).
METRICS_TOKEN=

# ─── Monitoring (Grafana/Prometheus) ─────────────────────────────────────────
# Used by docker-compose --profile monitoring
GRAFANA_PASSWORD=change_this_strong_password

# ─── STUN/TURN (Coturn NAT traversal) ────────────────────────────────────────
# Used by docker-compose --profile turn
TURN_USERNAME=ionevpn
TURN_PASSWORD=change_this_strong_password
AUTH_RATE_LIMIT_MAX=10
